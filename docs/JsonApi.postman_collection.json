{
  "info": {
    "name": "Apex JSON:API Framework",
    "description": "Manual test requests for the Apex JSON:API framework.\n\nSetup: set the `token` collection variable to a fresh access token\n(`sf org display -o jsonapi-org --json` -> result.accessToken). Tokens expire.\n\nNOTE: The API is READ-ONLY (GET only). POST/PATCH/DELETE are not supported\nand return 405 Method Not Allowed.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "instanceUrl",
      "value": "https://YOUR_DOMAIN.my.salesforce.com"
    },
    {
      "key": "baseUrl",
      "value": "{{instanceUrl}}/services/apexrest/jsonapi"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "accountId",
      "value": "REPLACE_WITH_ACCOUNT_ID"
    },
    {
      "key": "accountId2",
      "value": "REPLACE_WITH_ANOTHER_ACCOUNT_ID"
    },
    {
      "key": "contactId",
      "value": "REPLACE_WITH_CONTACT_ID"
    },
    {
      "key": "mediaType",
      "value": "application/json"
    }
  ],
  "item": [
    {
      "name": "Diagnostics",
      "item": [
        {
          "name": "Health (200 ok / 503 degraded)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "{{mediaType}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/_health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "_health"
              ]
            }
          }
        }
      ]
    },

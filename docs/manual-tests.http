###############################################################################
# JSON:API Framework — manual test requests
#
# Use with the VS Code "REST Client" extension (humao.rest-client).
# Click "Send Request" above any request below.
#
# 1. Set @instanceUrl to your org's My Domain URL, and @token to a fresh token:
#       sf org display -o jsonapi-org --json
#    -> result.instanceUrl  goes in @instanceUrl
#    -> result.accessToken  goes in @token   (tokens expire — refresh as needed)
#
# 2. Set @accountId / @contactId to real record Ids from your org (e.g. from the
#    "List accounts" / "List contacts" responses below).
#
# NOTE: The API is READ-ONLY (GET only). POST/PATCH/DELETE are not supported
#       and return 405 Method Not Allowed.
###############################################################################

@instanceUrl = https://YOUR_DOMAIN.my.salesforce.com
@baseUrl     = {{instanceUrl}}/services/apexrest/jsonapi
# Resources live under a version segment; _health is unversioned (uses {{baseUrl}}).
@v1          = {{baseUrl}}/v1
@v2          = {{baseUrl}}/v2
@token       = REPLACE_WITH_ACCESS_TOKEN
@accountId   = REPLACE_WITH_ACCOUNT_ID
@accountId2  = REPLACE_WITH_ANOTHER_ACCOUNT_ID
@contactId   = REPLACE_WITH_CONTACT_ID
@mediaType   = application/json


###############################################################################
# DIAGNOSTICS
###############################################################################

### Health — registered resources + any registration failures (200 ok / 503 degraded)
GET {{baseUrl}}/_health
Authorization: Bearer {{token}}
Accept: {{mediaType}}


###############################################################################
# ACCOUNTS — reads
###############################################################################

### List accounts
GET {{v1}}/accounts
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Single account
GET {{v1}}/accounts/{{accountId}}
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Sort (descending name)
GET {{v1}}/accounts?sort=-name
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Sort (multi: industry asc, name desc)
GET {{v1}}/accounts?sort=industry,-name
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Filter (equality)
GET {{v1}}/accounts?filter[industry]=Technology
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Filter (operator: greater-than-or-equal)
GET {{v1}}/accounts?filter[annualRevenue][gte]=1000000
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Filter (range: two conditions on one attribute, AND-ed)
GET {{v1}}/accounts?filter[annualRevenue][gte]=1000000&filter[annualRevenue][lt]=5000000
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Filter (in: comma-separated list)
GET {{v1}}/accounts?filter[industry][in]=Technology,Finance
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Filter (like: wildcard)
GET {{v1}}/accounts?filter[name][like]=Ac%25
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Filter by id (comma-separated -> IN)
GET {{v1}}/accounts?filter[id]={{accountId}},{{accountId2}}
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Sparse fieldsets
GET {{v1}}/accounts?fields[accounts]=name,phone
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Pagination (page-based)
GET {{v1}}/accounts?page[size]=5&page[number]=2
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Pagination (offset-based)
GET {{v1}}/accounts?page[limit]=5&page[offset]=10
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Extend — financials group
GET {{v1}}/accounts/{{accountId}}?extend=financials
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Extend — multiple groups
GET {{v1}}/accounts/{{accountId}}?extend=financials,contactInfo
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Include — to-one (parent)
GET {{v1}}/accounts/{{accountId}}?include=parent
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Include — to-many (contacts)
GET {{v1}}/accounts/{{accountId}}?include=contacts
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Include — nested (contacts.account)
GET {{v1}}/accounts/{{accountId}}?include=contacts.account
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Combined (filter + sort + extend + page)
GET {{v1}}/accounts?filter[industry]=Technology&sort=-name&extend=financials&page[size]=3
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Related — to-one (parent)
GET {{v1}}/accounts/{{accountId}}/parent
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Related — to-many (contacts)
GET {{v1}}/accounts/{{accountId}}/contacts
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Relationship linkage — to-one (parent)
GET {{v1}}/accounts/{{accountId}}/relationships/parent
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Relationship linkage — to-many (contacts)
GET {{v1}}/accounts/{{accountId}}/relationships/contacts
Authorization: Bearer {{token}}
Accept: {{mediaType}}


###############################################################################
# ACCOUNTS — v2 (same type, different version: base adds `rating`)
###############################################################################

### List accounts (v2)
GET {{v2}}/accounts
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Single account (v2) — response includes the extra `rating` attribute
GET {{v2}}/accounts/{{accountId}}
Authorization: Bearer {{token}}
Accept: {{mediaType}}


###############################################################################
# CONTACTS — reads
###############################################################################

### List contacts
GET {{v1}}/contacts
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Single contact
GET {{v1}}/contacts/{{contactId}}
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Sort (lastName)
GET {{v1}}/contacts?sort=lastName
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Filter
GET {{v1}}/contacts?filter[lastName]=Doe
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Sparse fieldsets
GET {{v1}}/contacts?fields[contacts]=firstName,lastName
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Pagination
GET {{v1}}/contacts?page[size]=5&page[number]=1
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Extend — contactInfo group
GET {{v1}}/contacts/{{contactId}}?extend=contactInfo
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Extend — multiple groups
GET {{v1}}/contacts/{{contactId}}?extend=contactInfo,professional
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Include — to-one (account)
GET {{v1}}/contacts/{{contactId}}?include=account
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Include — nested (account.contacts)
GET {{v1}}/contacts/{{contactId}}?include=account.contacts
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Related — to-one (account)
GET {{v1}}/contacts/{{contactId}}/account
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### Relationship linkage — to-one (account)
GET {{v1}}/contacts/{{contactId}}/relationships/account
Authorization: Bearer {{token}}
Accept: {{mediaType}}


###############################################################################
# ERROR CASES
###############################################################################

### 404 — unknown type
GET {{v1}}/widgets
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### 404 — unknown id
GET {{v1}}/accounts/001000000000000
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### 400 — bad sort field
GET {{v1}}/accounts?sort=bogus
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### 400 — bad extend group
GET {{v1}}/accounts?extend=bogus
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### 400 — bad filter field
GET {{v1}}/accounts?filter[bogus]=x
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### 405 — write method not allowed (read-only API)
POST {{v1}}/accounts
Authorization: Bearer {{token}}
Accept: {{mediaType}}

### 406 — parameterized Accept media type
GET {{v1}}/accounts
Authorization: Bearer {{token}}
Accept: application/vnd.api+json; charset=utf-8
